# Supabase — get these from your project's API Settings page
# https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Google Gemini — for vehicle classification on upload
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-key
# Model: gemini-1.5-flash-latest (1500 RPD free) or gemini-2.5-flash (20 RPD free, more accurate)
GEMINI_MODEL=gemini-1.5-flash-latest

# Optional: Supabase Personal Access Token, for running migrations via the CLI
# (not used by the app at runtime). Generate at:
# https://supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=your-sbp-token
